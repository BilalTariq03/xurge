{
  "rewrites": [
    { "source": "/work",           "destination": "/work.html" },
    { "source": "/services",       "destination": "/services.html" },
    { "source": "/projects",       "destination": "/projects.html" },
    { "source": "/contact",        "destination": "/contact.html" },
    { "source": "/projects/:slug", "destination": "/projects.html" },
    { "source": "/about",          "destination": "/about.html" },
    { "source": "/faq",            "destination": "/faq.html" },
    { "source": "/privacy-policy", "destination": "/privacy.html" },
    { "source": "/terms-of-use",   "destination": "/terms.html" },
    { "source": "/sitemap",        "destination": "/sitemap.html" }
  ]
}